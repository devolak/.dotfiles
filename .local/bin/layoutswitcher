#!/bin/bash

file="$HOME/.config/hypr/workspaces/dualmonitor.conf"
workspace=$(hyprctl -j activeworkspace)

layout=$(echo ${workspace} | jq -r '.tiledLayout')
id=$(echo ${workspace} | jq -r '.id')
line_number=$(sed -n "/ ${id},/=" ${file})

if [[ ${layout} == "master" ]]; then
  sed -i "${line_number}s/${layout}/monocle/" ${file}
elif [[ ${layout} == "monocle" ]]; then
  sed -i "${line_number}s/${layout}/scrolling/" ${file}
elif [[ ${layout} == "scrolling" ]]; then
  sed -i "${line_number}s/${layout}/master/" ${file}
else
  notify-send "layoutswitcher script failed"
fi
